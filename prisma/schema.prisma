generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  PAID
  OVERDUE
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum RecurrenceType {
  CONTINUOUS
  INSTALLMENTS
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  categories            Category[]
  suppliers             Supplier[]
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  rules                 CategorizationRule[]
}

model User {
  id          String    @id @default(cuid())
  name        String?
  email       String    @unique
  password    String
  role        Role      @default(VIEWER)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile   Profile?
  auditLogs AuditLog[]
}

model Profile {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio    String?
  avatar String?
}

model Category {
  id          String          @id @default(cuid())
  name        String
  type        TransactionType
  color       String          @default("#000000")
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  transactions Transaction[]
}

model Supplier {
  id          String    @id @default(cuid())
  name        String
  document    String? // CPF or CNPJ
  contact     String?
  address     String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  transactions Transaction[]
}

model Transaction {
  id         String            @id @default(cuid())
  type       TransactionType
  amount     Decimal           @db.Decimal(10, 2)
  date       DateTime          @default(now())
  dueDate    DateTime?
  status     TransactionStatus @default(PENDING)
  attachment String?
  notes      String?

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  isRecurring         Boolean         @default(false)
  recurrenceType      RecurrenceType?
  installments        Int?
  parentTransactionId String?
  parentTransaction   Transaction?    @relation("TransactionRecurrence", fields: [parentTransactionId], references: [id])
  childTransactions   Transaction[]   @relation("TransactionRecurrence")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecurringTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  description String
  amount      Decimal         @db.Decimal(10, 2)
  frequency   Frequency
  startDate   DateTime
  endDate     DateTime?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategorizationRule {
  id          String    @id @default(cuid())
  keyword     String
  categoryId  String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  details   Json?
  createdAt DateTime @default(now())
}
